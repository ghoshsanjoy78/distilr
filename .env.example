# Copy this file to `.env.local` and fill in your values.
# `.env.local` is gitignored; `.env.example` is committed as a template.

# ─── Provider selection ──────────────────────────────────────────────────────

# Which AI provider to use. Default: anthropic.
# Options: anthropic | openai | google | gemini | openrouter
# Override per-run with `--provider <name>` on the CLI.
# DISTILR_PROVIDER=anthropic

# Override the model used. Defaults are sensible per provider:
#   anthropic    → claude-sonnet-4-6
#   openai       → gpt-4o
#   google       → gemini-2.5-pro
#   openrouter   → anthropic/claude-sonnet-4-6
# Override per-run with `--model <name>` on the CLI.
# DISTILR_MODEL=

# ─── API keys ────────────────────────────────────────────────────────────────
# Set the key for whichever provider you've selected. Others can be left blank.

# Anthropic (default provider). Get one at https://console.anthropic.com/
ANTHROPIC_API_KEY=

# OpenAI. Get one at https://platform.openai.com/api-keys
OPENAI_API_KEY=

# Google Gemini. Get one at https://aistudio.google.com/app/apikey
GOOGLE_GENERATIVE_AI_API_KEY=

# OpenRouter (universal proxy). Get one at https://openrouter.ai/keys
OPENROUTER_API_KEY=
